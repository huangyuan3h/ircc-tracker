# Copy this file to .env and fill in your IRCC Tracker credentials.
#   cp .env.example .env
#   chmod 600 .env

# Cognito username (often your UCI)
TRACKER_USERNAME=YOUR_UCI

# Cognito password
TRACKER_PASSWORD=YOUR_PASSWORD

# Application number shown in IRCC Tracker
# Tip: leave blank and run ./ircc-check.sh --list to discover it
APP_NUMBER=YOUR_APPLICATION_NUMBER

# UCI number
UCI_NUMBER=YOUR_UCI

# Optional: relative paths are resolved from the project directory
# LOG_PATH=./StatusCheck.txt
