{
  "name": "ircc-checker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "npm run build:cf && wrangler pages dev .vercel/output/static --compatibility-date=2025-01-15 --compatibility-flag=nodejs_compat",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsx --test tests/*.test.ts",
    "test:bash": "bats tests/ircc-check.bats",
    "deploy": "npm run build:cf && wrangler deploy",
    "deploy:maintenance": "wrangler deploy --config wrangler.maintenance.toml",
    "deploy:preview": "npm run build:cf && wrangler deploy --keep-vars",
    "deploy:api": "cd workers/api && wrangler deploy",
    "deploy:all": "npm run deploy:api && npm run deploy"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.111.0"
  },
  "engines": {
    "node": "24.x"
  }
}
